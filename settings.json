{
    "Environment": {
        "Paths": {
            "BaseDirectory": "%LOCALAPPDATA%\\mpv",
            "UpdateDirectory": "%LOCALAPPDATA%\\mpv\\update",
            "AppCacheDirectories": [
                "%LOCALAPPDATA%\\mpv\\cache"
            ]
        },
        "ZipExecutablePath": "%ProgramFiles%\\7-Zip\\7z.exe"
    },
    "GlobalUpdateRules": {
        "VersionComparison": {
            "ForceUpdate": false,
            "OffsetMinutes": 60
        },
        "FileTypes": {
            "Executable": [".exe"],
            "Archive": [".7z", ".zip", ".tar.gz"]
        },
        "ExcludeList": ["cache", "watch_later", "update.lnk"],
        "ApiEndpoint": "https://api.github.com/repos/{0}/releases/latest"
    },
    "Apps": {
        "mpv": {
            "Executable": "mpv.exe",
            "UpdateTargets": [
                { "Pin": false, "Force": false, "Path": "sohnyj/minimal-mpv-winbuild", "Filter": "mpv-x86_64-v3" }
            ],
            "DeployTargets": ["mpv", "mpv.com", "mpv.exe"]
        },
        "ffmpeg": {
            "Executable": "ffmpeg.exe",
            "UpdateTargets": [
                { "Pin": false, "Force": false, "Path": "sohnyj/minimal-mpv-winbuild", "Filter": "ffmpeg-x86_64-v3" }
            ],
            "DeployTargets": []
        },
        "yt-dlp": {
            "Executable": "yt-dlp.exe",
            "UpdateTargets": [
                { "Pin": false, "Force": false, "Path": "yt-dlp/yt-dlp-nightly-builds", "Filter": "yt-dlp.exe" }
            ],
            "DeployTargets": []
        }
    },
    "AppCache": {
        "Clear": true,
        "ForceOnPartial": false
    },
    "ErrorActionPreference": "Continue",
    "ProgressPreference": "SilentlyContinue"
}
